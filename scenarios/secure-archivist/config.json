{
  "schemaVersion": 1,
  "id": "secure-archivist",
  "name": "Secure Archivist",
  "summary": "A privacy character for encrypted rooms, private channels, pairing, policy, redaction, observability, and local fallback.",
  "primaryJob": "Expose encrypted-state problems, redaction misses, pairing mistakes, private-channel drift, observability leaks, and tool-policy regressions.",
  "requiredEnv": [
    "MATRIX_ACCESS_TOKEN",
    "MATRIX_HOMESERVER",
    "NOSTR_PRIVATE_KEY",
    "NOSTR_RELAY_PRIMARY",
    "NOSTR_RELAY_SECONDARY",
    "OLLAMA_BASE_URL",
    "OPENCLAW_IRC_CHANNEL",
    "OPENCLAW_IRC_HOST",
    "OPENCLAW_IRC_NICK",
    "OPENCLAW_MATRIX_OPERATOR_USER",
    "OPENCLAW_MATRIX_SECURE_ROOM",
    "OPENCLAW_SIGNAL_ALLOWED_FROM",
    "SEARXNG_BASE_URL",
    "SIGNAL_ACCOUNT"
  ],
  "state": {
    "mode": "persistent",
    "resetPolicy": "keep-encrypted-and-admin-state",
    "defaultStateDir": ".state/secure-archivist"
  },
  "channels": [
    {
      "id": "matrix-e2ee",
      "name": "Matrix E2EE",
      "requiredEnv": [
        "MATRIX_ACCESS_TOKEN",
        "MATRIX_HOMESERVER",
        "MATRIX_RECOVERY_KEY",
        "OPENCLAW_MATRIX_SECURE_ROOM"
      ],
      "surfaces": [
        "encrypted-room",
        "verification",
        "restart-replay",
        "media",
        "dedupe"
      ]
    },
    {
      "id": "signal",
      "name": "Signal",
      "requiredEnv": [
        "OPENCLAW_SIGNAL_ALLOWED_FROM",
        "SIGNAL_ACCOUNT"
      ],
      "surfaces": [
        "private-channel-state",
        "pairing",
        "allowlist"
      ]
    },
    {
      "id": "nostr-irc",
      "name": "Nostr or IRC",
      "requiredEnv": [
        "NOSTR_PRIVATE_KEY",
        "NOSTR_RELAY_PRIMARY",
        "NOSTR_RELAY_SECONDARY",
        "OPENCLAW_IRC_CHANNEL",
        "OPENCLAW_IRC_HOST",
        "OPENCLAW_IRC_NICK"
      ],
      "surfaces": [
        "low-dependency-channel",
        "fallback-routing"
      ]
    },
    {
      "id": "control-ui-cli",
      "name": "Control UI and CLI status",
      "defaultBaseUrl": "http://localhost:18789/",
      "surfaces": [
        "pairing-admin",
        "policy-status",
        "logs",
        "redacted-observability"
      ]
    }
  ],
  "providers": [
    {
      "id": "openai",
      "name": "OpenAI",
      "role": "primary-model",
      "requiredEnv": [
        "OPENAI_API_KEY"
      ]
    },
    {
      "id": "local",
      "name": "Ollama, LM Studio, vLLM, or SGLang",
      "role": "local-fallback",
      "requiredEnv": [
        "OLLAMA_BASE_URL"
      ]
    },
    {
      "id": "searxng",
      "name": "SearXNG or DuckDuckGo",
      "role": "key-free-search",
      "requiredEnv": [
        "SEARXNG_BASE_URL"
      ]
    }
  ],
  "plugins": [
    "matrix",
    "signal",
    "nostr",
    "irc",
    "diagnostics-otel",
    "diagnostics-prometheus",
    "policy",
    "tokenjuice",
    "ollama",
    "lmstudio",
    "vllm",
    "searxng"
  ],
  "openclaw": {
    "sourceDocs": [
      "docs/channels/matrix.md",
      "docs/channels/signal.md",
      "docs/channels/nostr.md",
      "docs/channels/irc.md",
      "docs/providers/ollama.md",
      "docs/providers/lmstudio.md",
      "docs/providers/vllm.md",
      "docs/tools/searxng-search.md"
    ],
    "setupCommands": [
      "openclaw plugins install @openclaw/matrix",
      "openclaw plugins install @openclaw/nostr",
      "openclaw matrix encryption setup",
      "openclaw matrix verify status"
    ],
    "configPatch": {
      "models": {
        "providers": {
          "ollama": {
            "baseUrl": "${OLLAMA_BASE_URL}",
            "apiKey": "ollama-local"
          }
        }
      },
      "channels": {
        "matrix": {
          "enabled": true,
          "homeserver": "${MATRIX_HOMESERVER}",
          "accessToken": {
            "source": "env",
            "provider": "default",
            "id": "MATRIX_ACCESS_TOKEN"
          },
          "encryption": true,
          "dm": {
            "policy": "pairing",
            "sessionScope": "per-room",
            "threadReplies": "off"
          },
          "groupPolicy": "allowlist",
          "groupAllowFrom": [
            "${OPENCLAW_MATRIX_OPERATOR_USER}"
          ],
          "groups": {
            "${OPENCLAW_MATRIX_SECURE_ROOM}": {
              "requireMention": true
            }
          },
          "autoJoin": "allowlist",
          "autoJoinAllowlist": [
            "${OPENCLAW_MATRIX_SECURE_ROOM}"
          ],
          "threadReplies": "inbound",
          "replyToMode": "off",
          "streaming": "partial"
        },
        "signal": {
          "enabled": true,
          "account": "${SIGNAL_ACCOUNT}",
          "dmPolicy": "pairing",
          "allowFrom": [
            "${OPENCLAW_SIGNAL_ALLOWED_FROM}"
          ]
        },
        "nostr": {
          "enabled": true,
          "privateKey": "${NOSTR_PRIVATE_KEY}",
          "relays": [
            "${NOSTR_RELAY_PRIMARY}",
            "${NOSTR_RELAY_SECONDARY}"
          ]
        },
        "irc": {
          "enabled": true,
          "host": "${OPENCLAW_IRC_HOST}",
          "port": 6697,
          "tls": true,
          "nick": "${OPENCLAW_IRC_NICK}",
          "channels": [
            "${OPENCLAW_IRC_CHANNEL}"
          ]
        }
      },
      "tools": {
        "web": {
          "search": {
            "enabled": true,
            "provider": "searxng"
          }
        }
      },
      "plugins": {
        "entries": {
          "diagnostics-otel": {
            "enabled": true
          },
          "diagnostics-prometheus": {
            "enabled": true
          },
          "policy": {
            "enabled": true
          },
          "tokenjuice": {
            "enabled": true
          },
          "ollama": {
            "enabled": true
          },
          "lmstudio": {
            "enabled": true
          },
          "vllm": {
            "enabled": true
          },
          "searxng": {
            "enabled": true,
            "config": {
              "baseUrl": "${SEARXNG_BASE_URL}"
            }
          }
        }
      }
    }
  },
  "flows": [
    {
      "id": "matrix-e2ee-continuity",
      "title": "Matrix E2EE continuity",
      "steps": [
        "Exchange encrypted messages",
        "Restart OpenClaw",
        "Send follow-up"
      ],
      "assertions": [
        "E2EE state survives",
        "replay dedupe works",
        "room routing is correct"
      ]
    },
    {
      "id": "allowlist-enforcement",
      "title": "Allowlist enforcement",
      "steps": [
        "Send authorized request",
        "Send unauthorized request"
      ],
      "assertions": [
        "authorized request works",
        "unauthorized event is dropped or recorded safely",
        "no actionable session is created"
      ]
    },
    {
      "id": "pairing-device-approval",
      "title": "Pairing and device approval",
      "steps": [
        "Connect new Control UI device or channel node",
        "Approve",
        "Revoke",
        "Restart"
      ],
      "assertions": [
        "approval state survives restart",
        "revocation works",
        "device identifiers are not committed"
      ]
    },
    {
      "id": "tool-denial-policy-check",
      "title": "Tool denial and policy check",
      "steps": [
        "Ask for a high-risk command or private-channel action",
        "Deny or block the action through policy",
        "Inspect status and logs"
      ],
      "assertions": [
        "denial is explicit",
        "blocked action does not continue",
        "logs and status redact private context"
      ]
    },
    {
      "id": "observability-privacy",
      "title": "Observability privacy",
      "steps": [
        "Enable OTel and Prometheus",
        "Run representative messages and tool calls"
      ],
      "assertions": [
        "metrics include useful signals",
        "prompt and response content are not exported",
        "secrets and private paths are absent"
      ]
    }
  ],
  "artifacts": [
    "metric names",
    "policy denial event",
    "encrypted-room health",
    "redacted pairing summary"
  ],
  "neverCommit": [
    "recovery keys",
    "private room ids",
    "raw logs",
    "prompt content",
    "response content",
    "local endpoint credentials"
  ],
  "taxonomy": {
    "primary": [
      "matrix",
      "signal",
      "security-auth-pairing-and-secrets",
      "telemetry-diagnostics-and-observability"
    ],
    "secondary": [
      "mattermost-line-irc-nextcloud-talk-nostr-twitch-tlon-synology-chat",
      "local-model-providers-ollama-vllm-sglang-lm-studio",
      "channel-framework"
    ],
    "expectation": "Keep this character focused on private channels, pairing, policy, redaction, and observability; platform update and doctor survival belongs to Platform Custodian."
  }
}

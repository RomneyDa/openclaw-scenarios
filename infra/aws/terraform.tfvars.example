aws_region       = "us-east-2"
name_prefix      = "openclaw-scenarios"
repo_url         = "https://github.com/RomneyDa/openclaw-scenarios.git"
openclaw_package = "openclaw@beta"

# Start cheaper. Enable macOS only after accepting EC2 Mac Dedicated Host cost and 24h minimum allocation.
enable_linux   = true
enable_windows = true
enable_macos   = false

# Optional SSM SecureString parameter names. Create with scripts/aws/put-secret.mjs.
tailscale_auth_key_ssm_parameter = ""
openai_api_key_ssm_parameter     = ""

# Required only when enable_macos=true.
mac_ami_id = ""

#!/bin/bash
set -euo pipefail

INSTANCE_ID="${instance_id}"
SCENARIO_ROOT="/opt/openclaw-scenarios"
STATE_DIR="/var/lib/openclaw-scenario"
LOG_DIR="/var/log/openclaw-scenario"
OPENCLAW_PACKAGE="${openclaw_package}"
AWS_REGION="${aws_region}"

mkdir -p "$SCENARIO_ROOT" "$STATE_DIR" "$LOG_DIR"

if ! command -v brew >/dev/null 2>&1; then
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi
eval "$(/opt/homebrew/bin/brew shellenv || true)"
brew install node@24 git jq awscli || true

if ! command -v openclaw >/dev/null 2>&1; then
  npm install -g "$OPENCLAW_PACKAGE"
fi

if [[ -n "${tailscale_auth_key_ssm_parameter}" ]]; then
  brew install --cask tailscale || true
  auth_key="$(aws ssm get-parameter --region "$AWS_REGION" --name "${tailscale_auth_key_ssm_parameter}" --with-decryption --query 'Parameter.Value' --output text)"
  /Applications/Tailscale.app/Contents/MacOS/Tailscale up --auth-key "$auth_key" --hostname "oc-scenario-$INSTANCE_ID" --ssh=false || true
fi

if [[ ! -d "$SCENARIO_ROOT/.git" ]]; then
  git clone "${repo_url}" "$SCENARIO_ROOT"
else
  git -C "$SCENARIO_ROOT" pull --ff-only || true
fi

if [[ -n "${openai_api_key_ssm_parameter}" ]]; then
  aws ssm get-parameter --region "$AWS_REGION" --name "${openai_api_key_ssm_parameter}" --with-decryption --query 'Parameter.Value' --output text > "$STATE_DIR/openai_api_key"
  chmod 0600 "$STATE_DIR/openai_api_key"
fi

cat > "$STATE_DIR/env" <<EOF
OPENCLAW_SCENARIO_ID=$INSTANCE_ID
OPENCLAW_HOME=$STATE_DIR/home
OPENCLAW_STATE_DIR=$STATE_DIR/home
OPENCLAW_GATEWAY_PORT=18789
EOF
if [[ -f "$STATE_DIR/openai_api_key" ]]; then
  printf 'OPENAI_API_KEY=%s\n' "$(cat "$STATE_DIR/openai_api_key")" >> "$STATE_DIR/env"
fi
chmod 0600 "$STATE_DIR/env"

cat > /usr/local/bin/openclaw-scenario-collect <<'EOF'
#!/bin/bash
set -euo pipefail
source /var/lib/openclaw-scenario/env
cd /opt/openclaw-scenarios
npm run collect:local -- --instance "$OPENCLAW_SCENARIO_ID"
EOF
chmod 0755 /usr/local/bin/openclaw-scenario-collect

cat > /Library/LaunchDaemons/ai.openclaw.scenario.gateway.plist <<'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>ai.openclaw.scenario.gateway</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>source /var/lib/openclaw-scenario/env; openclaw gateway run --bind loopback --port "$OPENCLAW_GATEWAY_PORT" --auth none --allow-unconfigured</string>
  </array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>WorkingDirectory</key><string>/var/lib/openclaw-scenario</string>
  <key>StandardOutPath</key><string>/var/log/openclaw-scenario/gateway.log</string>
  <key>StandardErrorPath</key><string>/var/log/openclaw-scenario/gateway.err.log</string>
</dict>
</plist>
EOF

launchctl bootstrap system /Library/LaunchDaemons/ai.openclaw.scenario.gateway.plist || true

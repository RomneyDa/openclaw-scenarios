# OpenClaw scenario environment template
# Copy to .env on the device running scenarios. Leave unused values blank.

# Providers
OPENAI_API_KEY='' # OpenAI Platform key for models, image, realtime, and TTS
ANTHROPIC_API_KEY='' # Anthropic Console key for Claude ACP fallback
GOOGLE_API_KEY='' # Google AI/Gemini key for Gemini ACP and media/voice options
DEEPGRAM_API_KEY='' # Deepgram console key for STT
ELEVENLABS_API_KEY='' # ElevenLabs dashboard key for TTS
BRAVE_API_KEY='' # Brave Search API dashboard key
TAVILY_API_KEY='' # Tavily dashboard key
FAL_API_KEY='' # fal dashboard key
RUNWAY_API_KEY='' # Runway API key for video generation
MINIMAX_API_KEY='' # MiniMax key for media/TTS checks
SEARXNG_BASE_URL='' # Self-hosted SearXNG URL
OPENCLAW_LOCAL_MODEL_ENDPOINT='' # Local Ollama/LM Studio/vLLM/SGLang endpoint

# Local scenario state
OPENCLAW_PERSONAL_CONCIERGE_STATE_DIR='' # Personal Concierge state directory
OPENCLAW_TEAM_DISPATCHER_STATE_DIR='' # Team Dispatcher state directory
OPENCLAW_ENTERPRISE_LIAISON_STATE_DIR='' # Enterprise Liaison state directory
OPENCLAW_CODING_FOREMAN_STATE_DIR='' # Coding Foreman state directory
OPENCLAW_CODING_FOREMAN_REPO_DIR='' # Local repo used by Coding Foreman
OPENCLAW_RESEARCH_LIBRARIAN_STATE_DIR='' # Research Librarian state directory
OPENCLAW_MEDIA_STUDIO_STATE_DIR='' # Media Studio state directory
OPENCLAW_VOICE_HOST_STATE_DIR='' # Voice Host state directory
OPENCLAW_SECURE_ARCHIVIST_STATE_DIR='' # Secure Archivist state directory

# Local web surfaces
OPENCLAW_CONTROL_UI_BASE_URL='' # Control UI URL on the scenario device
OPENCLAW_WEBCHAT_BASE_URL='' # WebChat URL on the scenario device

# Slack
SLACK_APP_TOKEN='' # Slack app-level token from Basic Information
SLACK_BOT_TOKEN='' # Slack Bot User OAuth token from Install App
OPENCLAW_SLACK_CODING_CHANNEL_ID='' # Slack channel for Coding Foreman
OPENCLAW_SLACK_CODING_THREAD='' # Slack thread for bound Coding Foreman checks
OPENCLAW_SLACK_TRIAGE_CHANNEL_ID='' # Slack triage channel for Team Dispatcher

# Discord
DISCORD_BOT_TOKEN='' # Discord Developer Portal bot token
DISCORD_APPLICATION_ID='' # Discord application/client ID
OPENCLAW_DISCORD_OPERATOR_USER_ID='' # Operator user ID from Developer Mode
OPENCLAW_DISCORD_GUILD_ID='' # Team Dispatcher guild/server ID
OPENCLAW_DISCORD_MEDIA_GUILD_ID='' # Media Studio guild/server ID

# Telegram
TELEGRAM_BOT_TOKEN='' # BotFather token
OPENCLAW_TELEGRAM_RESEARCH_USER_ID='' # Research Librarian operator user ID
OPENCLAW_TELEGRAM_MEDIA_USER_ID='' # Media Studio operator user ID
OPENCLAW_TELEGRAM_RESEARCH_CHAT_ID='' # Research Librarian chat/group ID
OPENCLAW_TELEGRAM_MEDIA_CHAT_ID='' # Media Studio chat/group ID

# WhatsApp and iMessage
OPENCLAW_PERSONAL_WHATSAPP_ALLOWED_FROM='' # Allowed WhatsApp sender for Personal Concierge
OPENCLAW_PERSONAL_WHATSAPP_GROUP_ID='' # WhatsApp group ID for mention-gating checks
OPENCLAW_IMSG_CLI_PATH='' # imsg CLI or wrapper path
OPENCLAW_IMESSAGE_DB_PATH='' # macOS Messages chat.db path

# SMS and voice calls
TWILIO_ACCOUNT_SID='' # Twilio Account SID
TWILIO_AUTH_TOKEN='' # Twilio Auth Token
TWILIO_PHONE_NUMBER='' # Twilio SMS sender number
SMS_PUBLIC_WEBHOOK_URL='' # Twilio SMS webhook URL
TWILIO_FROM_NUMBER='' # Twilio voice sender number
OPENCLAW_VOICE_CALL_TEST_NUMBER='' # Voice Host call target number
OPENCLAW_VOICE_PUBLIC_URL='' # Voice Call plugin webhook URL
OPENCLAW_GOOGLE_MEET_TEST_ROOM='' # Google Meet test room URL or code

# Microsoft Teams
MSTEAMS_APP_ID='' # Teams app client ID
MSTEAMS_APP_PASSWORD='' # Teams app client secret
MSTEAMS_TENANT_ID='' # Teams tenant ID
OPENCLAW_MSTEAMS_OPERATOR_ID='' # Teams operator identifier

# Google Chat
GOOGLECHAT_SERVICE_ACCOUNT_JSON='' # Google Chat service-account JSON or env SecretRef value
OPENCLAW_GOOGLECHAT_AUDIENCE='' # Google Chat app audience URL
OPENCLAW_GOOGLECHAT_BOT_USER='' # Google Chat bot user resource name
OPENCLAW_GOOGLECHAT_OPERATOR_USER='' # Google Chat operator user resource name
OPENCLAW_GOOGLECHAT_SPACE='' # Google Chat space resource name

# Feishu / Lark
FEISHU_APP_ID='' # Feishu developer console app ID
FEISHU_APP_SECRET='' # Feishu app secret
FEISHU_ENCRYPT_KEY='' # Feishu event encrypt key
FEISHU_VERIFICATION_TOKEN='' # Feishu event verification token
OPENCLAW_WEBHOOK_SHARED_SECRET='' # Shared secret for scenario webhook requests

# Mattermost and Nextcloud Talk
MATTERMOST_SERVER_URL='' # Mattermost server URL
MATTERMOST_BOT_TOKEN='' # Mattermost bot token
MATTERMOST_TEAM='' # Mattermost team name or slug
NEXTCLOUD_TALK_SERVER_URL='' # Nextcloud server URL
NEXTCLOUD_TALK_USERNAME='' # Nextcloud username
NEXTCLOUD_TALK_APP_PASSWORD='' # Nextcloud app password
NEXTCLOUD_TALK_ROOM_TOKEN='' # Nextcloud Talk room token

# LINE and Zalo
LINE_CHANNEL_ACCESS_TOKEN='' # LINE Developers channel access token
LINE_CHANNEL_SECRET='' # LINE Developers channel secret
OPENCLAW_LINE_MEDIA_USER_ID='' # LINE user ID for Media Studio
ZALO_OA_ID='' # Zalo Official Account ID
ZALO_ACCESS_TOKEN='' # Zalo access token

# Matrix
MATRIX_HOMESERVER='' # Matrix homeserver URL
MATRIX_ACCESS_TOKEN='' # Matrix access token
MATRIX_RECOVERY_KEY='' # Matrix E2EE recovery key
OPENCLAW_MATRIX_RESEARCH_ROOM='' # Matrix room for Research Librarian
OPENCLAW_MATRIX_OPERATOR_USER='' # Matrix operator user ID
OPENCLAW_MATRIX_SECURE_ROOM='' # Matrix room for Secure Archivist

# Signal
SIGNAL_ACCOUNT='' # signal-cli account
SIGNAL_CLI_PATH='' # signal-cli executable path
SIGNAL_CLI_CONFIG_PATH='' # signal-cli config directory
OPENCLAW_SIGNAL_ALLOWED_FROM='' # Allowed Signal sender

# Nostr and IRC
NOSTR_PRIVATE_KEY='' # Nostr private key, preferably env-backed only
NOSTR_RELAY_URLS='' # Comma-separated Nostr relay URLs
OPENCLAW_IRC_HOST='' # IRC server host
OPENCLAW_IRC_NICK='' # IRC bot nick
OPENCLAW_IRC_CHANNEL='' # IRC channel name

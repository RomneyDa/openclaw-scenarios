# OpenClaw scenario environment template
#
# Copy this to .env on the device that will run scenarios. Leave unused scenario
# values blank. Do not commit your filled .env file.

## Shared model and media providers
# OpenAI Platform key, or the key used by the OpenClaw process for direct OpenAI API access.
OPENAI_API_KEY=

# Anthropic API key for Claude ACP fallback runs.
ANTHROPIC_API_KEY=

# Google/Gemini API key for Gemini ACP, grounded tasks, and optional voice/media providers.
GOOGLE_API_KEY=

# Deepgram API key for STT and realtime transcription checks.
DEEPGRAM_API_KEY=

# ElevenLabs API key for TTS checks.
ELEVENLABS_API_KEY=

# Brave Search API key from the Brave Search API dashboard.
BRAVE_API_KEY=

# Tavily API key from the Tavily dashboard.
TAVILY_API_KEY=

# fal API key from the fal dashboard.
FAL_API_KEY=

# Runway API key for video generation checks.
RUNWAY_API_KEY=

# MiniMax API key for music, video, image, or TTS checks.
MINIMAX_API_KEY=

# Self-hosted SearXNG base URL for key-free search checks.
SEARXNG_BASE_URL=

## Local scenario state and workspace paths
# Local directory for Personal Concierge state.
OPENCLAW_PERSONAL_CONCIERGE_STATE_DIR=

# Local directory for Team Dispatcher state.
OPENCLAW_TEAM_DISPATCHER_STATE_DIR=

# Local directory for Enterprise Liaison state.
OPENCLAW_ENTERPRISE_LIAISON_STATE_DIR=

# Local directory for Coding Foreman state.
OPENCLAW_CODING_FOREMAN_STATE_DIR=

# Local repository path used by Coding Foreman.
OPENCLAW_CODING_FOREMAN_REPO_DIR=

# Control UI base URL for local browser-driven scenarios.
OPENCLAW_CONTROL_UI_BASE_URL=

# WebChat base URL for local browser-driven scenarios.
OPENCLAW_WEBCHAT_BASE_URL=

# Local directory for Research Librarian state.
OPENCLAW_RESEARCH_LIBRARIAN_STATE_DIR=

# Local directory for Media Studio state.
OPENCLAW_MEDIA_STUDIO_STATE_DIR=

# Local directory for Voice Host state.
OPENCLAW_VOICE_HOST_STATE_DIR=

# Local directory for Secure Archivist state.
OPENCLAW_SECURE_ARCHIVIST_STATE_DIR=

## Slack
# Slack app-level token from Basic Information > App-Level Tokens.
SLACK_APP_TOKEN=

# Slack Bot User OAuth token from Install App.
SLACK_BOT_TOKEN=

# Slack channel ID used by Coding Foreman.
OPENCLAW_SLACK_CODING_CHANNEL_ID=

# Slack thread ID used by Coding Foreman bound-thread checks.
OPENCLAW_SLACK_CODING_THREAD=

# Slack channel ID used by Team Dispatcher triage.
OPENCLAW_SLACK_TRIAGE_CHANNEL_ID=

## Discord
# Discord bot token from the Discord Developer Portal.
DISCORD_BOT_TOKEN=

# Discord application/client ID from the Developer Portal.
DISCORD_APPLICATION_ID=

# Discord operator user ID copied with Developer Mode.
OPENCLAW_DISCORD_OPERATOR_USER_ID=

# Discord guild/server ID for Team Dispatcher.
OPENCLAW_DISCORD_GUILD_ID=

# Discord guild/server ID for Media Studio.
OPENCLAW_DISCORD_MEDIA_GUILD_ID=

## Telegram
# Telegram bot token from BotFather.
TELEGRAM_BOT_TOKEN=

# Telegram user ID allowed to operate Research Librarian.
OPENCLAW_TELEGRAM_RESEARCH_USER_ID=

# Telegram user ID allowed to operate Media Studio.
OPENCLAW_TELEGRAM_MEDIA_USER_ID=

# Telegram chat or group ID for Research Librarian.
OPENCLAW_TELEGRAM_RESEARCH_CHAT_ID=

# Telegram chat or group ID for Media Studio.
OPENCLAW_TELEGRAM_MEDIA_CHAT_ID=

## WhatsApp and iMessage
# WhatsApp sender ID or phone number allowed to operate Personal Concierge.
OPENCLAW_PERSONAL_WHATSAPP_ALLOWED_FROM=

# WhatsApp group ID used by Personal Concierge mention-gating checks.
OPENCLAW_PERSONAL_WHATSAPP_GROUP_ID=

# Path to the imsg CLI or wrapper used by the iMessage plugin.
OPENCLAW_IMSG_CLI_PATH=

# Path to the local macOS Messages chat database.
OPENCLAW_IMESSAGE_DB_PATH=

## SMS and voice calls
# Twilio Account SID.
TWILIO_ACCOUNT_SID=

# Twilio Auth Token.
TWILIO_AUTH_TOKEN=

# Twilio SMS sender number for the SMS channel.
TWILIO_PHONE_NUMBER=

# Public webhook URL for Twilio SMS delivery.
SMS_PUBLIC_WEBHOOK_URL=

# Twilio voice sender number for the Voice Call plugin.
TWILIO_FROM_NUMBER=

# Voice-call target number for Voice Host smoke checks.
OPENCLAW_VOICE_CALL_TEST_NUMBER=

# Public webhook URL for the Voice Call plugin.
OPENCLAW_VOICE_PUBLIC_URL=

# Google Meet test room URL or code for Voice Host.
OPENCLAW_GOOGLE_MEET_TEST_ROOM=

## Microsoft Teams
# Teams app client ID from Teams/Azure app creation.
MSTEAMS_APP_ID=

# Teams app client secret.
MSTEAMS_APP_PASSWORD=

# Teams tenant ID.
MSTEAMS_TENANT_ID=

# Teams operator identifier allowed in the test room.
OPENCLAW_MSTEAMS_OPERATOR_ID=

## Google Chat
# Google Chat service-account JSON payload or env-backed SecretRef value.
GOOGLECHAT_SERVICE_ACCOUNT_JSON=

# Google Chat app audience URL.
OPENCLAW_GOOGLECHAT_AUDIENCE=

# Google Chat bot user resource name used for mention detection.
OPENCLAW_GOOGLECHAT_BOT_USER=

# Google Chat operator user resource name.
OPENCLAW_GOOGLECHAT_OPERATOR_USER=

# Google Chat space resource name for Enterprise Liaison.
OPENCLAW_GOOGLECHAT_SPACE=

## Feishu / Lark
# Feishu app ID from the developer console.
FEISHU_APP_ID=

# Feishu app secret.
FEISHU_APP_SECRET=

# Feishu event encrypt key.
FEISHU_ENCRYPT_KEY=

# Feishu event verification token.
FEISHU_VERIFICATION_TOKEN=

# Shared secret used by authenticated webhook scenario requests.
OPENCLAW_WEBHOOK_SHARED_SECRET=

## Mattermost and Nextcloud Talk
# Mattermost server URL.
MATTERMOST_SERVER_URL=

# Mattermost bot token.
MATTERMOST_BOT_TOKEN=

# Mattermost team name or slug.
MATTERMOST_TEAM=

# Nextcloud Talk server URL.
NEXTCLOUD_TALK_SERVER_URL=

# Nextcloud username.
NEXTCLOUD_TALK_USERNAME=

# Nextcloud app password.
NEXTCLOUD_TALK_APP_PASSWORD=

# Nextcloud Talk room token.
NEXTCLOUD_TALK_ROOM_TOKEN=

## LINE and Zalo
# LINE channel access token from the LINE Developers console.
LINE_CHANNEL_ACCESS_TOKEN=

# LINE channel secret from the LINE Developers console.
LINE_CHANNEL_SECRET=

# LINE user ID allowed to operate Media Studio.
OPENCLAW_LINE_MEDIA_USER_ID=

# Zalo Official Account ID.
ZALO_OA_ID=

# Zalo access token.
ZALO_ACCESS_TOKEN=

## Matrix
# Matrix homeserver URL.
MATRIX_HOMESERVER=

# Matrix access token.
MATRIX_ACCESS_TOKEN=

# Matrix recovery key for E2EE verification or restore flows.
MATRIX_RECOVERY_KEY=

# Matrix room ID or alias for Research Librarian.
OPENCLAW_MATRIX_RESEARCH_ROOM=

# Matrix user ID allowed to operate Secure Archivist.
OPENCLAW_MATRIX_OPERATOR_USER=

# Matrix room ID or alias for Secure Archivist.
OPENCLAW_MATRIX_SECURE_ROOM=

## Signal
# Signal account number or account identifier used by signal-cli.
SIGNAL_ACCOUNT=

# Path to signal-cli.
SIGNAL_CLI_PATH=

# signal-cli config directory.
SIGNAL_CLI_CONFIG_PATH=

# Signal sender allowed to operate Secure Archivist.
OPENCLAW_SIGNAL_ALLOWED_FROM=

## Nostr and IRC
# Nostr private key. Prefer using OpenClaw channel setup with env-backed config.
NOSTR_PRIVATE_KEY=

# Comma-separated Nostr relay URLs.
NOSTR_RELAY_URLS=

# IRC server host.
OPENCLAW_IRC_HOST=

# IRC bot nick.
OPENCLAW_IRC_NICK=

# IRC channel name for Secure Archivist.
OPENCLAW_IRC_CHANNEL=

## Local fallback providers
# Local model endpoint used for Secure Archivist fallback experiments.
OPENCLAW_LOCAL_MODEL_ENDPOINT=
